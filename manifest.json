{
  "manifest_version": 3,
  "name": "Discord 用户消息搜索导出",
  "version": "1.1.0",
  "description": "搜索并导出 Discord 中指定用户的所有发言记录（页面内悬浮窗，支持 JSON / CSV / TXT / HTML）。",
  "permissions": ["storage"],
  "host_permissions": ["https://discord.com/*"],
  "background": {
    "service_worker": "src/background.js"
  },
  "action": {
    "default_title": "打开 / 关闭 Discord 消息导出悬浮窗"
  },
  "content_scripts": [
    {
      "matches": ["https://discord.com/*"],
      "js": ["src/inject.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["https://discord.com/*"],
      "js": ["src/content.js"],
      "run_at": "document_idle",
      "world": "ISOLATED"
    }
  ]
}
